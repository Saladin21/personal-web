---
import BaseLayout from "../layouts/BaseLayout.astro";

const skillGroups = [
  ["AI / ML", ["PyTorch", "scikit-learn", "ONNX", "OpenCV", "embeddings", "segmentation", "detection"]],
  ["LLM / Agents", ["RAG", "Qdrant", "LangGraph", "tool calling", "LLM APIs", "prompt workflows"]],
  ["Backend", ["Python", "FastAPI", "Flask", "Redis", "RabbitMQ", "REST APIs", "webhooks"]],
  ["Cloud / Infra", ["Docker", "AWS", "GCP", "S3/GCS", "Cloudflare Pages", "VPS deployment"]],
  ["Automation", ["n8n", "Telegram", "Gmail", "Postgres", "workflow automation"]],
];
---

<BaseLayout
  title="CV - Ahmad Saladin"
  description="CV summary for Ahmad Saladin, a remote AI/ML engineer focused on LLM/RAG apps, computer vision pipelines, AI backend systems, and automation."
  sideBarActiveItemID="cv"
>
  <section class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary">CV</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">Ahmad Saladin</h1>
    <p class="mt-4 text-xl">Remote AI/ML Engineer for production AI systems</p>
    <p class="mt-3 opacity-80">Based in Indonesia, UTC+7. Available for APAC/Europe overlap and async global teams.</p>
    <div class="mt-6 flex flex-wrap gap-3">
      <span class="btn btn-disabled">CV PDF coming soon</span>
      <a class="btn btn-primary" href="/contact">Contact Me</a>
    </div>
  </section>

  <section class="mt-10 card bg-base-200 shadow-sm">
    <div class="card-body">
      <h2 class="card-title">Role Summary</h2>
      <p>I help teams build LLM/RAG apps, computer vision pipelines, FastAPI model APIs, vector search systems, n8n automations, and cloud inference backends.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-3xl font-bold">Core Skills</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {skillGroups.map(([group, skills]) => (
        <article class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <h3 class="font-bold">{group}</h3>
            <div class="flex flex-wrap gap-2">
              {skills.map((skill) => <span class="badge badge-outline">{skill}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-3xl font-bold">Selected Experience Areas</h2>
    <div class="mt-6 grid gap-4">
      <article class="card bg-base-200 shadow-sm"><div class="card-body"><h3 class="card-title">LLM/RAG Engineering</h3><p>Retrieval pipelines, vector search, tool-calling workflows, structured outputs, and AI app backend integration.</p></div></article>
      <article class="card bg-base-200 shadow-sm"><div class="card-body"><h3 class="card-title">Computer Vision Engineering</h3><p>Image processing, segmentation, detection, model inference, post-processing, and deployment-oriented API design.</p></div></article>
      <article class="card bg-base-200 shadow-sm"><div class="card-body"><h3 class="card-title">AI Backend Engineering</h3><p>FastAPI/Flask model APIs, queue workers, object storage flows, status tracking, callbacks, and cloud deployment patterns.</p></div></article>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-3xl font-bold">Relevant Case Studies</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <a class="card bg-base-200 shadow-sm hover:bg-base-300" href="/case-studies/llm-rag-assistant"><div class="card-body"><h3 class="font-bold">LLM/RAG Assistant</h3><p>Case study coming soon</p></div></a>
      <a class="card bg-base-200 shadow-sm hover:bg-base-300" href="/case-studies/computer-vision-segmentation"><div class="card-body"><h3 class="font-bold">CV Segmentation</h3><p>Case study coming soon</p></div></a>
      <a class="card bg-base-200 shadow-sm hover:bg-base-300" href="/case-studies/async-ai-inference-backend"><div class="card-body"><h3 class="font-bold">Async Inference Backend</h3><p>Case study coming soon</p></div></a>
    </div>
  </section>

  <section class="mt-10 card bg-primary text-primary-content shadow-sm">
    <div class="card-body">
      <h2 class="card-title text-2xl">Interested in working together?</h2>
      <p>Use the contact page to share the role, project, or AI/backend system you want to build.</p>
      <div class="card-actions"><a class="btn" href="/contact">Contact Me</a></div>
    </div>
  </section>
</BaseLayout>
