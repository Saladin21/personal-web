---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Ahmad Saladin - Remote AI/ML Engineer";
const description = "Remote AI/ML engineer based in Indonesia, building production LLM/RAG apps, computer vision pipelines, FastAPI model APIs, and AI automation workflows.";

const capabilities = [
  {
    title: "LLM/RAG Applications",
    description: "Document assistants, retrieval pipelines, vector search, tool-calling workflows, structured data collection, and AI app backends. Built for enterprise clients in healthcare and business automation.",
    tags: ["Python", "FastAPI", "Qdrant", "LangGraph", "RAG", "Tool Calling"],
  },
  {
    title: "Computer Vision Systems",
    description: "Image processing, segmentation, detection, OpenCV/PyTorch pipelines, sliding-window inference, post-processing, and production inference APIs. Deployed to both cloud APIs and mobile devices (TorchScript + JNI).",
    tags: ["PyTorch", "OpenCV", "ONNX", "Segmentation", "Detection", "Sliding-Window Inference"],
  },
  {
    title: "AI Backend & Model Serving",
    description: "FastAPI/Flask model APIs, async job queues, Redis/RabbitMQ workers, object storage flows, callback/webhook patterns, and cloud deployment. Serving real-time healthcare workflows and long-running inference jobs.",
    tags: ["FastAPI", "Flask", "Redis", "RabbitMQ", "Docker", "AWS", "GCP", "S3/GCS"],
  },
  {
    title: "n8n + AI Automation",
    description: "Workflow automations combining APIs, LLMs, webhooks, human approval, messaging integrations, and business process automation. Built for business process automation with LLM integration.",
    tags: ["n8n", "Webhooks", "LLMs", "Gmail", "Telegram", "Postgres", "Automation"],
  },
];

const caseStudies = [
  {
    title: "LLM/RAG Assistant with Tool Calling",
    description: "AI assistant workflow with retrieval, tool calling, structured information collection, and backend integration.",
    href: "/case-studies/llm-rag-assistant",
    tags: ["LLM", "RAG", "Qdrant", "FastAPI", "LangGraph", "Tool Calling"],
  },
  {
    title: "Computer Vision Segmentation Pipeline",
    description: "Production-oriented image segmentation workflow with preprocessing, sliding-window inference, post-processing, API/mobile deployment considerations, and visualization outputs.",
    href: "/case-studies/computer-vision-segmentation",
    tags: ["Computer Vision", "PyTorch", "OpenCV", "Segmentation", "ONNX", "API Deployment"],
  },
  {
    title: "Async AI Inference Backend",
    description: "Backend architecture for long-running AI jobs using API endpoints, queue workers, object storage, status tracking, and callback/webhook delivery.",
    href: "/case-studies/async-ai-inference-backend",
    tags: ["FastAPI", "Flask", "Redis", "RabbitMQ", "Docker", "AWS", "GCP", "S3/GCS"],
  },
];

const stackGroups = [
  ["AI / ML", ["PyTorch", "scikit-learn", "ONNX", "OpenCV", "embeddings", "segmentation", "detection", "LangChain", "LlamaIndex"]],
  ["LLM / Agents", ["RAG", "Qdrant", "FAISS", "LangGraph", "tool calling", "OpenAI API", "Gemini API", "GPT-Realtime", "prompt workflows"]],
  ["Backend", ["Python", "FastAPI", "Flask", "Redis", "RabbitMQ", "REST APIs", "webhooks", "async pipelines"]],
  ["Cloud / Infra", ["Docker", "AWS", "GCP", "S3/GCS", "Cloudflare Pages", "VPS deployment"]],
  ["Languages", ["Python", "JavaScript/TypeScript", "SQL", "Kotlin", "C/C++"]],
  ["Automation", ["n8n", "Telegram", "Gmail", "Postgres", "workflow automation"]],
];
---

<BaseLayout title={title} description={description} includeSidebar={true}>
  <section class="pb-14 mt-4">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary">Ahmad Saladin</p>
    <h1 class="mt-3 text-4xl md:text-6xl font-bold leading-tight">Remote AI/ML Engineer for production AI systems</h1>
    <p class="mt-5 text-lg md:text-xl leading-relaxed max-w-3xl">
      I help teams build LLM/RAG apps, computer vision pipelines, FastAPI model APIs, vector search systems, n8n automations, and cloud inference backends.
    </p>
    <div class="mt-5 grid gap-2 text-base opacity-80">
      <p>Based in Indonesia, UTC+7. Available for APAC/Europe overlap and async global teams.</p>
      <p>Open to remote roles, contractor work, freelance projects, part-time engagements, and project-based AI/backend implementation.</p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a class="btn btn-primary" href="/case-studies">View Case Studies</a>
      <a class="btn btn-outline" href="/cv">View CV</a>
      <a class="btn btn-ghost" href="/contact">Contact Me</a>
    </div>
    <div class="mt-5 flex flex-wrap gap-3 text-sm opacity-75">
      <a href="https://github.com/Saladin21" target="_blank" rel="noopener noreferrer" class="link link-hover">GitHub</a>
      <a href="https://linkedin.com/in/ahmad-saladin/" target="_blank" rel="noopener noreferrer" class="link link-hover">LinkedIn</a>
      <a href="https://www.kaggle.com/ahmadsaladin" target="_blank" rel="noopener noreferrer" class="link link-hover">Kaggle</a>
      <a href="mailto:ahmadsaladin21@gmail.com" class="link link-hover">Email</a>
    </div>
  </section>

  <section class="py-10">
    <h2 class="text-3xl font-bold">What I Build</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {capabilities.map((item) => (
        <article class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <h3 class="card-title">{item.title}</h3>
            <p>{item.description}</p>
            <div class="mt-2 flex flex-wrap gap-2">
              {item.tags.map((tag) => <span class="badge badge-outline">{tag}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="py-10">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <h2 class="text-3xl font-bold">Featured Case Studies</h2>
      <a class="link link-primary" href="/case-studies">View all case studies</a>
    </div>
    <div class="mt-6 grid gap-4">
      {caseStudies.map((item) => (
        <article class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <h3 class="card-title">{item.title}</h3>
               <span class="badge badge-primary badge-outline">Case study</span>
            </div>
            <p>{item.description}</p>
            <div class="flex flex-wrap gap-2">
              {item.tags.map((tag) => <span class="badge badge-outline">{tag}</span>)}
            </div>
            <div class="card-actions justify-end">
               <a class="btn btn-sm btn-outline" href={item.href}>Read case study</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>



  <section class="py-10">
    <h2 class="text-3xl font-bold">Available for roles and project work</h2>
    <p class="mt-3 max-w-3xl opacity-80">I am available for remote AI/ML engineering roles, contractor engagements, freelance PoCs, part-time implementation support, and project-based AI/backend work.</p>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <article class="card bg-base-200 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">For Hiring Teams</h3>
          <p>Looking for an AI/ML engineer who can build production-oriented systems, not just experiments.</p>
          <ul class="list-disc pl-5 grid gap-1">
            <li>AI/ML Engineer</li>
            <li>LLM/RAG Engineer</li>
            <li>Computer Vision Engineer</li>
            <li>AI Backend Engineer</li>
            <li>Python Backend Engineer with ML deployment experience</li>
          </ul>
          <div class="card-actions justify-end"><a class="btn btn-outline" href="/cv">View CV</a></div>
        </div>
      </article>
      <article class="card bg-base-200 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">For Clients & Agencies</h3>
          <p>Need help building AI prototypes, backend integrations, computer vision pipelines, RAG apps, or workflow automations.</p>
          <ul class="list-disc pl-5 grid gap-1">
            <li>RAG/document assistant prototypes</li>
            <li>Computer vision pipelines</li>
            <li>Async model inference APIs</li>
            <li>AI workflow automation</li>
            <li>n8n + LLM implementation</li>
            <li>Backend integration for AI products</li>
          </ul>
          <div class="card-actions justify-end"><a class="btn btn-primary" href="/contact">Contact Me</a></div>
        </div>
      </article>
    </div>
  </section>

  <section class="py-10">
    <h2 class="text-3xl font-bold">Tech Stack</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {stackGroups.map(([group, items]) => (
        <article class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <h3 class="font-bold">{group}</h3>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => <span class="badge badge-outline">{item}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="py-10">
    <h2 class="text-3xl font-bold">Availability</h2>
    <div class="mt-4 card bg-base-200 shadow-sm">
      <div class="card-body">
        <p>Based in Indonesia, UTC+7. Available for APAC/Europe overlap and async global teams.</p>
        <p>Open to remote roles, contractor work, freelance projects, part-time engagements, and project-based AI/backend implementation.</p>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="card bg-primary text-primary-content shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-3xl">Can I help you build this AI system?</h2>
        <p>Start with the case studies or reach out directly with the system you want to build.</p>
        <div class="card-actions mt-3">
          <a class="btn" href="/contact">Contact Me</a>
          <a class="btn btn-outline border-primary-content text-primary-content hover:bg-primary-content hover:text-primary" href="/case-studies">View Case Studies</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
