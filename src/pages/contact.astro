---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact - Ahmad Saladin"
  description="Contact Ahmad Saladin for remote AI/ML engineering roles, contractor work, freelance projects, and AI/backend implementation."
  sideBarActiveItemID="contact"
>
  <section class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary">Contact</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">Build a production AI system with me</h1>
    <p class="mt-4 text-lg opacity-80">Open to remote roles, contractor work, freelance projects, part-time engagements, and project-based AI/backend implementation.</p>
  </section>

  <section class="mt-10 grid gap-4 md:grid-cols-2">
    <article class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <h2 class="card-title">Contact Details</h2>
        <p><strong>Email:</strong> <a href="mailto:ahmadsaladin21@gmail.com" class="link link-primary">ahmadsaladin21@gmail.com</a></p>
        <p><strong>LinkedIn:</strong> <a href="https://linkedin.com/in/ahmad-saladin/" target="_blank" rel="noopener noreferrer" class="link link-primary">linkedin.com/in/ahmad-saladin</a></p>
        <p><strong>GitHub:</strong> <a href="https://github.com/Saladin21" target="_blank" rel="noopener noreferrer" class="link link-primary">github.com/Saladin21</a></p>
        <p><strong>Kaggle:</strong> <a href="https://www.kaggle.com/ahmadsaladin" target="_blank" rel="noopener noreferrer" class="link link-primary">kaggle.com/ahmadsaladin</a></p>
        <p><strong>Phone:</strong> +62 817625440</p>
      </div>
    </article>
    <article class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <h2 class="card-title">Availability</h2>
        <p><strong>Location:</strong> Indonesia, UTC+7</p>
        <p><strong>Overlap:</strong> APAC/Europe overlap and async global teams</p>
        <p><strong>Work types:</strong> Remote roles, contractor work, freelance projects, part-time engagements, and project-based AI/backend implementation.</p>
      </div>
    </article>
  </section>

  <section class="mt-10 card bg-primary text-primary-content shadow-sm">
    <div class="card-body">
      <h2 class="card-title text-2xl">Good fit projects</h2>
      <p>LLM/RAG apps, computer vision pipelines, FastAPI model APIs, async inference backends, vector search systems, n8n automations, and AI backend integrations.</p>
      <div class="card-actions mt-3">
        <a class="btn" href="/case-studies">View Case Studies</a>
        <a class="btn btn-outline border-primary-content text-primary-content hover:bg-primary-content hover:text-primary" href="/pocs">View PoCs</a>
      </div>
    </div>
  </section>
</BaseLayout>
